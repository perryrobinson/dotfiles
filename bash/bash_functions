#!/usr/bin/env bash
# ~/.bash_functions: custom functions

# Create a directory and cd into it
mkcd() {
    mkdir -p "$1" && cd "$1"
}

# Extract various archive formats to a folder with the same name
extract() {
    if [ ! -f "$1" ]; then
        echo "'$1' is not a valid file"
        return 1
    fi

    # Strip multi-part extensions properly (.tar.gz, .tar.bz2, etc.)
    local base
    base=$(basename "$1")
    case "$base" in
        *.tar.bz2|*.tar.gz|*.tar.xz) base="${base%.*.*}" ;;
        *)                            base="${base%.*}"    ;;
    esac

    mkdir -p "$base" && cd "$base" || return 1

    case "$1" in
        *.tar.bz2)   tar xjf "../$1"     ;;
        *.tar.gz)    tar xzf "../$1"     ;;
        *.tar.xz)    tar xJf "../$1"     ;;
        *.bz2)       bunzip2 "../$1"     ;;
        *.rar)       unrar e "../$1"     ;;
        *.gz)        gunzip "../$1"      ;;
        *.tar)       tar xf "../$1"      ;;
        *.tbz2)      tar xjf "../$1"     ;;
        *.tgz)       tar xzf "../$1"     ;;
        *.zip)       unzip "../$1"       ;;
        *.Z)         uncompress "../$1"  ;;
        *.7z)        7z x "../$1"        ;;
        *)           echo "'$1' cannot be extracted via extract()" ;;
    esac

    cd ..
}

# Create a backup of a file with date
backup() {
    cp "$1" "$1.bak.$(date +%Y%m%d%H%M%S)"
}

# dos2unix - convert line endings, skipping .git and binary files
d2u() {
    local target="${1:-.}"
    find "$target" -type f \
        -not -path '*/.git/*' \
        -not -path '*/node_modules/*' \
        -not -path '*/.venv/*' \
        | while IFS= read -r file; do
            if file "$file" | grep -q text; then
                dos2unix "$file"
            fi
        done
}
