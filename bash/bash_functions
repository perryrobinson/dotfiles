#!/usr/bin/env bash
# ~/.bash_functions: custom functions

# Create a directory and cd into it
mkcd() {
    mkdir -p "$1" && cd "$1"
}

# Extract various archive formats to a folder with the same name
extract() {
    if [ -f $1 ] ; then
        # Get filename without extension
        local dirname=$(basename "$1" | sed 's/\.[^.]*$//')
        mkdir -p "$dirname" && cd "$dirname"
        
        case $1 in
            *.tar.bz2)   tar xjf ../$1     ;;
            *.tar.gz)    tar xzf ../$1     ;;
            *.bz2)       bunzip2 ../$1     ;;
            *.rar)       unrar e ../$1     ;;
            *.gz)        gunzip ../$1      ;;
            *.tar)       tar xf ../$1      ;;
            *.tbz2)      tar xjf ../$1     ;;
            *.tgz)       tar xzf ../$1     ;;
            *.zip)       unzip ../$1       ;;
            *.Z)         uncompress ../$1  ;;
            *.7z)        7z x ../$1        ;;
            *)           echo "'$1' cannot be extracted via extract()" ;;
        esac
        
        cd ..
    else
        echo "'$1' is not a valid file"
    fi
}

# Create a backup of a file with date
backup() {
    cp "$1" "$1.bak.$(date +%Y%m%d%H%M%S)"
}

# dos2unix - convert line endings, skipping .git and binary files
d2u() {
    local target="${1:-.}"
    find "$target" -type f \
        -not -path '*/.git/*' \
        -not -path '*/node_modules/*' \
        -not -path '*/.venv/*' \
        | while IFS= read -r file; do
            if file "$file" | grep -q text; then
                dos2unix "$file"
            fi
        done
}
